{
  "name": "vibe99",
  "productName": "Vibe99",
  "version": "0.4.4",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Electron interaction proof of concept for Vibe99",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "check:node": "node ./scripts/check-supported-node.mjs",
    "build:config": "tsc -p tsconfig.config.json",
    "prepare:native": "node ./scripts/prepare-native-modules.mjs",
    "prestart": "npm run check:node && npm run build:config && npm run prepare:native",
    "start": "node ./scripts/run-electron.mjs",
    "precapture": "npm run check:node && npm run build:config && npm run prepare:native",
    "capture": "node ./scripts/run-electron.mjs --capture",
    "prepackage": "npm run check:node && npm run build:config && npm run prepare:native",
    "package": "node ./scripts/run-package-command.mjs package",
    "premake": "npm run check:node && npm run build:config && npm run prepare:native",
    "make": "node ./scripts/run-package-command.mjs make",
    "release:notes": "node ./scripts/extract-release-notes.mjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron/rebuild": "^4.0.1",
    "7zip-bin": "^5.2.0",
    "electron": "^36.0.0",
    "electron-windows": "npm:electron@29.4.6",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  },
  "build": {
    "appId": "com.vibe99.app",
    "productName": "Vibe99",
    "electronVersion": "29.4.6",
    "compression": "store",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "out/builder",
      "buildResources": "assets"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "src/**/*",
      "package.json",
      "!electron/config.ts"
    ],
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**"
    ],
    "npmRebuild": false,
    "win": {
      "icon": "assets/icons/icon.ico",
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-portable-${arch}.${ext}",
      "unpackDirName": "Vibe99Portable"
    }
  }
}
