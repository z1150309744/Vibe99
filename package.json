{
  "name": "vibe99",
  "productName": "Vibe99",
  "version": "0.4.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Electron interaction proof of concept for Vibe99",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "check:node": "node ./scripts/check-supported-node.mjs",
    "build:config": "tsc -p tsconfig.config.json",
    "prepare:native": "node ./scripts/ensure-node-pty-runtime.mjs",
    "prestart": "npm run check:node && npm run build:config && npm run prepare:native",
    "start": "electron .",
    "precapture": "npm run check:node && npm run build:config && npm run prepare:native",
    "capture": "VIBE99_CAPTURE=1 electron .",
    "prepackage": "npm run check:node && npm run build:config && npm run prepare:native",
    "package": "electron-forge package",
    "premake": "npm run check:node && npm run build:config && npm run prepare:native",
    "make": "electron-forge make",
    "release:notes": "node ./scripts/extract-release-notes.mjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron/rebuild": "^4.0.1",
    "electron": "^36.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  }
}
