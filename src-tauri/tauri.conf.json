{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Vibe99",
  "version": "0.6.0",
  "identifier": "com.vibe99.app",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe99",
        "width": 1600,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "backgroundColor": "#111111",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
